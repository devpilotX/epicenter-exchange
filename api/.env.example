# Epicenter Exchange API configuration
# Copy to .env and fill in real values. Never commit .env.

# ---- Server ----
DB_PATH=/data/epicenter.db
API_URL=https://api.epicenterexchange.com
ALLOWED_ORIGINS=https://epicenterexchange.com,https://www.epicenterexchange.com

# ---- SMTP (Resend) ----
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
# Get fresh API key from https://resend.com/api-keys
# IMPORTANT: paste in plain text (no rich-text copy from browser).
# Real key is ~36 chars starting with re_. If yours is much longer, you pasted wrong.
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Senders (public-facing) ----
FROM_EMAIL=hello@epicenterexchange.com
FROM_NAME=Epicenter Exchange

FROM_EMAIL_CONTACT=hello@epicenterexchange.com
FROM_NAME_CONTACT=Epicenter Exchange

FROM_EMAIL_NEWSLETTER=insights@epicenterexchange.com
FROM_NAME_NEWSLETTER=Epicenter Insights

# ---- Admin notification recipient (internal, NEVER shown in user emails) ----
# Set to your own inbox where you want to receive contact-form submissions.
NOTIFY_EMAIL=hello@epicenterexchange.com
