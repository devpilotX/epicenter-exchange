# Epicenter Exchange API — environment variables
# Copy to .env and fill in real values. NEVER commit .env to git.
DB_PATH=/data/epicenter.db
API_URL=https://api.epicenterexchange.com

# ============================================================
# SMTP — Resend (3,000 emails/month free, branded
# @epicenterexchange.com, excellent inbox placement)
# Sign up: https://resend.com  -> verify domain -> API Keys -> create
# ============================================================
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxxxxx   # API key from Resend (starts with re_)

# Default sender (fallback if per-route values below aren't set)
FROM_EMAIL=hello@epicenterexchange.com
FROM_NAME=Epicenter Exchange

# ============================================================
# Per-route senders — cleaner inboxes & easier filtering
# ============================================================
# Contact form replies & admin alerts
FROM_EMAIL_CONTACT=hello@epicenterexchange.com
FROM_NAME_CONTACT=Epicenter Exchange

# Newsletter welcomes & broadcasts
FROM_EMAIL_NEWSLETTER=insights@epicenterexchange.com
FROM_NAME_NEWSLETTER=Epicenter Insights

# Where admin copies of contact submissions land
NOTIFY_EMAIL=dipanshu@paisareality.com

# ============================================================
# Alternative SMTP providers (uncomment to use, comment out Resend block above)
# ============================================================
# Hostinger Business mailbox
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_USER=hello@epicenterexchange.com
# SMTP_PASS=your-mailbox-password

# paisareality.com mailbox (no Hostinger website-slot dance)
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_USER=hello@paisareality.com
# SMTP_PASS=your-mailbox-password

# Local dev only
# ALLOW_LOCALHOST=1
